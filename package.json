{
  "name": "jucart",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.25.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "backup:supabase": "scripts/backup-supabase.sh",
    "backup:supabase:cron:install": "scripts/install-supabase-backup-cron.sh",
    "recategorize:codex": "scripts/recategorize-with-codex.sh",
    "recategorize:codex:cron:install": "scripts/install-codex-recategorization-cron.sh",
    "supabase:db:push": "supabase db push",
    "supabase:link": "supabase link",
    "supabase:login": "supabase login",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "VITE_SUPABASE_URL= VITE_SUPABASE_ANON_KEY= VITE_SUPABASE_LIST_ID= pnpm build && playwright test",
    "test:e2e:headed": "VITE_SUPABASE_URL= VITE_SUPABASE_ANON_KEY= VITE_SUPABASE_LIST_ID= pnpm build && playwright test --headed",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@supabase/supabase-js": "2.110.3",
    "animejs": "4.5.0",
    "dexie": "4.4.4",
    "embla-carousel-react": "8.6.0",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "fake-indexeddb": "6.2.5",
    "globals": "17.7.0",
    "jsdom": "29.1.1",
    "prettier": "3.9.5",
    "sass": "1.101.0",
    "supabase": "2.109.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.63.0",
    "vite": "8.1.4",
    "vite-plugin-pwa": "1.3.0",
    "vitest": "4.1.10",
    "workbox-window": "7.4.1"
  }
}
